{
  "name": "company-community",
  "version": "0.1.0",
  "private": true,
  "description": "Corporate community platform - Blind + Reddit + Karrot hybrid",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "type-check": "turbo run type-check",
    "db:push": "turbo run db:push --filter=@repo/db",
    "db:migrate": "turbo run db:migrate --filter=@repo/db",
    "db:studio": "turbo run db:studio --filter=@repo/db"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "turbo": "^1.13.3",
    "typescript": "^5.3.3",
    "@repo/typescript-config": "workspace:*"
  },
  "packageManager": "pnpm@9.0.6",
  "engines": {
    "node": "22.x",
    "pnpm": ">=9.0.0"
  }
}
