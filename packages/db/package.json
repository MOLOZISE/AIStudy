    "db:generate": "drizzle-kit generate:pg",
    "db:seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.38.4",
    "drizzle-orm": "^0.30.8",
    "postgres": "^3.4.3"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@repo/types": "workspace:*",
    "@types/node": "^20.11.5",
    "drizzle-kit": "^0.20.13",
    "typescript": "^5.3.3"
  }
